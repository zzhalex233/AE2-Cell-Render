.gradle
**/build/
!src/**/build/
docs/
run/
out/

# Ignore Gradle GUI config
gradle-app.setting

# Avoid ignoring Gradle wrapper jar file (.jar files are usually ignored)
!gradle-wrapper.jar

# Avoid ignore Gradle wrappper properties
!gradle-wrapper.properties

# Cache of project
.gradletasknamecache

# Eclipse Gradle plugin generated files
# Eclipse Core
.project
# JDT-specific (Eclipse Java Development Tools)
.classpath

# IDEA config
.idea

# Local compatibility test drop-ins (LazyAE2 jar goes into local-test-mods/1.12.2/)
local-test-mods/

